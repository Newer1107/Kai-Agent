# Example .env file for Kai Agent

# Enable optional LLM-based intent parsing (default: 0)
KAI_ENABLE_INTENT_LLM=0

# Path to YOLO model weights (default: yolov8n.pt)
KAI_YOLO_WEIGHTS=./yolov8n.pt

# Dynamic step budget for autopilot mode (default: 10)
KAI_AUTOPILOT_STEP_BUDGET=10

# Log level (default: INFO)
KAI_LOG_LEVEL=INFO

# Optional: Ollama API key for code-gen path
OLLAMA_API_KEY=

# Optional: Proxy settings for network requests
HTTP_PROXY=
HTTPS_PROXY=

# Optional: Debug mode (default: 0)
KAI_DEBUG_MODE=0

# Optional: Path to session store
KAI_SESSION_STORE=./memory/session_store.py